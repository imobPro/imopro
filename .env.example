# ─────────────────────────────────────────────────────────────────────────────
# ImobBot SaaS — Variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env no repositório.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Aplicação ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Encontre em: app.supabase.com → Projeto → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Claude API (Anthropic) ───────────────────────────────────────────────────
# Encontre em: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── OpenAI (Whisper — transcrição de áudio) ──────────────────────────────────
# Encontre em: platform.openai.com → API Keys
# Usado exclusivamente para transcrição de áudio via Whisper-1
OPENAI_API_KEY=sk-your-openai-key-here

# Modelos conforme estratégia definida no CLAUDE.md
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-6         # Desenvolvimento do dia a dia
CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001    # Tarefas rápidas e boilerplate
CLAUDE_SMART_MODEL=claude-opus-4-6             # Arquitetura e decisões críticas

# ─── Agente de IA — configuração por tenant (Sprint 5 moverá para banco) ──────
AGENT_NAME=Assistente            # Nome do agente exibido para o lead
REALTY_NAME=Imobiliária          # Nome da imobiliária
ZAPI_CORRETOR_PHONE=5521999999999  # WhatsApp do corretor para alertas de sentimento negativo (com DDI)

# ─── Z-API (WhatsApp) ─────────────────────────────────────────────────────────
# Encontre em: app.z-api.io → Instância → Configurações
ZAPI_BASE_URL=https://api.z-api.io
ZAPI_INSTANCE_ID=your-instance-id
ZAPI_TOKEN=your-instance-token
ZAPI_CLIENT_TOKEN=your-client-token   # Token de segurança do webhook

# ─── Redis / BullMQ ──────────────────────────────────────────────────────────
# Redis para fila de processamento de mensagens
REDIS_URL=redis://localhost:6379

# ─── JWT (Autenticação) ───────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# ─── Stripe (Pagamentos) ──────────────────────────────────────────────────────
# Encontre em: dashboard.stripe.com → Developers → API Keys
STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ─── Asaas (Pagamentos — alternativa brasileira) ──────────────────────────────
# Encontre em: app.asaas.com → Configurações → Integrações
ASAAS_API_KEY=your-asaas-api-key
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3   # Trocar para produção depois

# ─── N8N Cloud (Automações e webhooks) ───────────────────────────────────────
N8N_WEBHOOK_BASE_URL=https://your-instance.app.n8n.cloud/webhook
N8N_API_KEY=your-n8n-api-key

# ─── E-mail (Envio de relatórios automáticos) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="ImobBot <noreply@imobbot.com.br>"

# ─── Frontend — Next.js (variáveis públicas) ─────────────────────────────────
# Estas variáveis são expostas ao navegador — não coloque secrets aqui
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
