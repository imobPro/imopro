# Frontend — variáveis de ambiente (Next.js)
# Copie para .env.local e preencha com os valores reais do seu projeto Supabase.
# NUNCA commite .env.local — apenas este arquivo de exemplo.

# Supabase — obter em app.supabase.com → Projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# URL pública da aplicação (usada em redirects de auth)
NEXT_PUBLIC_APP_URL=http://localhost:3000
